{
  "version": 2,
  "regions": ["sfo1"],
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "pages/**/*.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "admin/**/*.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "*.php",
      "use": "vercel-php@0.9.0"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "buildCommand": "npm run build || echo 'No build command'",
  "outputDirectory": "."
}
