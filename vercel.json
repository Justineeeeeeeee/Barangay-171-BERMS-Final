{
  "version": 2,
  "regions": ["sfo1"],
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.php"
    },
    {
      "source": "/:path*.php",
      "destination": "/api/index.php"
    }
  ],
  "buildCommand": "npm run build || echo 'No build command'",
  "outputDirectory": "."
}
