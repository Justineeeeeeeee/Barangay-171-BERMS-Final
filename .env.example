# Barangay Emergency Response and Monitoring System (BERMS) Environment Configuration
# Copy this file to .env and update the values for your deployment environment

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=incident_system

# Application Configuration
APP_NAME=BERMS
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/barangay171emergencyresponseandmonitoringsystem

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,avi

# Email Configuration (for future use)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@berms.gov.ph
MAIL_FROM_NAME=BERMS System

# Security Configuration
SESSION_LIFETIME=7200
JWT_SECRET=your-jwt-secret-key-here

# Admin Configuration
ADMIN_EMAIL=admin@berms.gov.ph
ADMIN_USERNAME=admin

# Barangay Information
BARANGAY_NAME=Barangay 171
BARANGAY_CAPTAIN=John Dela Cruz
BARANGAY_CONTACT=+63 917-123-4567

# Emergency Contacts
EMERGENCY_FIRE=+63 917-123-4567
EMERGENCY_AMBULANCE=+63 917-234-5678
EMERGENCY_POLICE=+63 917-345-6789

# API Keys (for future integrations)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
SMS_API_KEY=your-sms-api-key
EMAIL_API_KEY=your-email-api-key